              <calculation class='tableau' formula='IF [Department] = &quot;Sales&quot; &#13;&#10;   AND [JobSatisfaction] = &quot;Unsatisfied&quot; &#13;&#10;   AND [BusinessTravel] = &quot;Travel_Frequently&quot; &#13;&#10;   THEN &quot;Critical Risk&quot;&#13;&#10;ELSEIF [Department] = &quot;Research &amp; Development&quot; &#13;&#10;   AND [YearsSinceLastPromotion] &gt;= 3 &#13;&#10;   THEN &quot;High Risk&quot;&#13;&#10;ELSEIF [WorkLifeBalance] = 1 &#13;&#10;   AND [YearsAtCompany] &lt; 2 &#13;&#10;   THEN &quot;High Risk&quot;&#13;&#10;ELSEIF [JobSatisfaction] = &quot;Somewhat Satisfied&quot; &#13;&#10;   AND [PercentSalaryHike] &lt; 13 &#13;&#10;   THEN &quot;Medium Risk&quot;&#13;&#10;ELSE &quot;Low Risk&quot;&#13;&#10;END' />
            </column>
