      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0jca4gn15iqaw51719bvo0kvxm1d].[cnt:EmployeeNo.:qk]&quot;' value='Total Employees' />
