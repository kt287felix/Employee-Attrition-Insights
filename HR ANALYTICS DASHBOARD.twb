      </column>
      <column aggregation='None' caption='Age (bin)' datatype='integer' name='[Age (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='0' formula='[Age]' peg='0' size-parameter='[Parameters].[Parameter 1]' />
      </column>
      <column datatype='integer' name='[Age]' role='measure' type='quantitative' />
      <column caption='Business Travel' datatype='string' name='[BusinessTravel]' role='dimension' type='nominal' />
      <column caption='Risk Profile' datatype='string' name='[Calculation_133982149289504769]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Department] = &quot;Sales&quot; &#13;&#10;   AND [JobSatisfaction] = &quot;Unsatisfied&quot; &#13;&#10;   AND [BusinessTravel] = &quot;Travel_Frequently&quot; &#13;&#10;   THEN &quot;Critical Risk&quot;&#13;&#10;ELSEIF [Department] = &quot;Research &amp; Development&quot; &#13;&#10;   AND [YearsSinceLastPromotion] &gt;= 3 &#13;&#10;   THEN &quot;High Risk&quot;&#13;&#10;ELSEIF [WorkLifeBalance] = 1 &#13;&#10;   AND [YearsAtCompany] &lt; 2 &#13;&#10;   THEN &quot;High Risk&quot;&#13;&#10;ELSEIF [JobSatisfaction] = &quot;Somewhat Satisfied&quot; &#13;&#10;   AND [PercentSalaryHike] &lt; 13 &#13;&#10;   THEN &quot;Medium Risk&quot;&#13;&#10;ELSE &quot;Low Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='Age Band' datatype='string' name='[Calculation_133982149310885890]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt; 25 THEN &quot;1. Under 25&quot;&#13;&#10;ELSEIF [Age] &lt;= 34 THEN &quot;2. Age 25-34&quot;&#13;&#10;ELSEIF [Age] &lt;= 44 THEN &quot;3. Age 35-44&quot;&#13;&#10;ELSEIF [Age] &lt;= 54 THEN &quot;4. Age 45-54&quot;&#13;&#10;ELSE &quot;5. Age 55+&quot;&#13;&#10;END' />
        <aliases>
          <alias key='&quot;1. Under 25&quot;' value=' Under 25' />
          <alias key='&quot;2. Age 25-34&quot;' value='Age 25-34' />
          <alias key='&quot;3. Age 35-44&quot;' value='Age 35-44' />
          <alias key='&quot;4. Age 45-54&quot;' value='Age 45-54' />
          <alias key='&quot;5. Age 55+&quot;' value='Age 55+' />
        </aliases>
      </column>
      <column caption='Attrition Count' datatype='integer' name='[Calculation_434315949098868737]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Status]= &quot;Former&quot; THEN 1 ELSE 0 &#13;&#10;END' />
      </column>
      <column caption='Attrition Rate' datatype='real' name='[Calculation_434315949099302914]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_434315949098868737]) / COUNT([EmployeeNo.])' />
      </column>
      <column caption='Active Employees' datatype='integer' name='[Calculation_434315949100744707]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([EmployeeNo.]) - SUM([Calculation_434315949098868737])' />
      </column>
      <column datatype='string' name='[Department]' role='dimension' type='nominal' />
      <column caption='Education Field' datatype='string' name='[EducationField]' role='dimension' type='nominal' />
      <column datatype='integer' name='[EmployeeNo.]' role='measure' type='quantitative' />
      <column datatype='string' name='[Gender]' role='dimension' type='nominal' />
      <column caption='Job Role' datatype='string' name='[JobRole]' role='dimension' type='nominal' />
      <column aggregation='CountD' caption='Job Satisfaction' datatype='string' name='[JobSatisfaction]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;Satisfied&quot;' value='3' />
          <alias key='&quot;Somewhat Satisfied&quot;' value='2' />
          <alias key='&quot;Unsatisfied&quot;' value='1' />
          <alias key='&quot;Very Satisfied&quot;' value='4' />
